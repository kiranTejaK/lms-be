# ── Environment ───────────────────────────────────────────────────────
ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password1234
DB_NAME=prac_db

# ── Redis ────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_NAME=0

# ── Application ──────────────────────────────────────────────────────
APP_PREFIX=doit
CACHE_VERSION=v1

# ── Logging ──────────────────────────────────────────────────────────
LOG_DIR=logs
LOG_LEVEL=INFO
LOG_JSON=true
LOG_MAX_BYTES=5000000
LOG_BACKUP_COUNT=5
ENABLE_FILE_LOGGING=true
ENABLE_REQUEST_LOGGING=true

# ── JWT Authentication ───────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRY_IN_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRY_IN_MINUTES=10080

# ── Email / SMTP (Brevo) ────────────────────────────────────────────
BREVO_SMTP_SERVER=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASSWORD=
EMAIL_FROM_NAME=Learning Platform
EMAIL_FROM_EMAIL=noreply@learningplatform.com

# ── AWS S3 ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
